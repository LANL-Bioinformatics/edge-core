###############################################################################
# Refer to `./src/config.js` to see all supported environment variables.      #
###############################################################################
VITE_NAME=EDGEv3
# user/password authentication
VITE_USER_AUTH_ENABLED=false
VITE_EMAIL_NOTIFICATION_ENABLED=false
# feature flag for enabling/disabling customer support
VITE_SUPPORT_ENABLED=false
VITE_SUPPORT_EMAIL=edge@lanl.gov
# feature flag for enabling/disabling bulk submissions
VITE_BULK_SUBMISSIONS_ENABLED=false
# data
VITE_FILEUPLOAD_ENABLED=true
VITE_FILEUPLOAD_FOLDER_ENABLED=true
VITE_SRADATA_ENABLED=false

# for development only
# VITE_API_URL=http://localhost:5000

# ORCiD login
VITE_ORCID_AUTH_ENABLED=true
VITE_ORCID_CLIENT_ID=__POPULATE_ME_IF_ENABLING_ORCID_AUTH__
